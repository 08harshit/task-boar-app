# Copy to .env and fill in secrets.
# Supabase / database (see your project dashboard)
# DATABASE_URL=
#
# If the API in Docker logs: getaddrinfo EAI_AGAIN ...pooler.supabase.com
#  - That is DNS failing inside the container (transient or network/VPN/Docker DNS).
#  - Try Supabase Dashboard → Database → use "Direct connection" URI (db.<ref>.supabase.co:5432).
#  - Confirm pooler uses host *.pooler.supabase.com (not .co).
#  - Restart Docker Desktop / disable VPN / fix /etc/docker/daemon.json "dns" if on Linux.
#  - Optional: DATABASE_FORCE_IPV4=true (also applied automatically when URL contains "supabase")
# DATABASE_FORCE_IPV4=true
#
# REDIS_URL — required for task edit locks (TTL).
# - Dev on host:  docker compose up -d redis   then  redis://localhost:6379
# - API in Docker (see repo docker-compose `api` service):  redis://redis:6379
#   (localhost inside a container is NOT your laptop; use the compose service name.)
# - Redis on host, API in Docker (Linux may need extra_hosts):  redis://host.docker.internal:6379
REDIS_URL=redis://localhost:6379
TASK_LOCK_TTL_SECONDS=30

# Docker Compose only: map API to another host port when 3000 is busy (export before `docker compose up`)
# API_HOST_PORT=3001
